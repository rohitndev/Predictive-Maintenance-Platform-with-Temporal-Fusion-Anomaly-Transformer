# Copy to .env and fill in to enable optional cloud integrations.
# Every variable is OPTIONAL — leave blank to run the platform fully offline.

# --- InfluxDB Cloud (sensor TSDB) ---
INFLUXDB_URL=
INFLUXDB_TOKEN=
INFLUXDB_ORG=
INFLUXDB_BUCKET=sensors

# --- AWS (S3 artifacts + Lambda serving) ---
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# --- Groq (CMMS LangChain agent) ---
GROQ_API_KEY=
GROQ_MODEL=mixtral-8x7b-32768

# --- External CMMS (SAP PM / ServiceMax) ---
CMMS_API_URL=

# --- Experiment tracking / registry ---
WANDB_API_KEY=
MLFLOW_TRACKING_URI=
